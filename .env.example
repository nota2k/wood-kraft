# Copier ce fichier en .env (dev) et .env.production (prod)

# URL de base de l'API Laravel (sans trailing slash)
# Option A (recommandé en dev avec Vite) : URL relative — le proxy Vite (vite.config.js) relaie vers Laravel
#   VITE_API_BASE_URL=/api/v1
#   VITE_APP_URL=
#   Lancer : php artisan serve (défaut :8000) ou définir VITE_DEV_BACKEND_URL si autre port
# Option B : URL absolue vers Laravel (pas de proxy nécessaire)
#   VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
#   VITE_APP_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=/api/v1

# Cible du proxy dev (uniquement si VITE_API_BASE_URL commence par /)
# VITE_DEV_BACKEND_URL=http://127.0.0.1:8000

# URL de l'application Laravel (pour CSRF Sanctum si tu appelles le backend en direct)
# Laisser vide en dev si tu utilises le proxy + URLs relatives
VITE_APP_URL=
