# Copier ce fichier en .env (dev) et .env.production (prod)

# URL de base de l'API Laravel (sans trailing slash)
# dev  : http://127.0.0.1:8888/api/v1
# prod : https://api.woodkraft.nellybabillon.fr/api/v1
VITE_API_BASE_URL=http://127.0.0.1:8888/api/v1

# URL de l'application frontend (pour le cookie CSRF Sanctum)
# dev  : http://127.0.0.1:8888
# prod : https://woodkraft.nellybabillon.fr
VITE_APP_URL=http://127.0.0.1:8888
